# Backend Environment Variables

# Database
DATABASE_URL=mongodb://your_mongodb_connection_string

# JWT Secret (used for password reset tokens)
JWT_SECRET=your_secret_key_here_min_32_characters_recommended

# Email Configuration (for password reset emails)
# Using Gmail - You need to generate an App Password (not your regular password)
# Steps: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Frontend URL (for password reset link in emails)
FRONTEND_URL=http://localhost:3000

# Note: For Gmail:
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App Password for your Gmail account
# 3. Use the app password (16 characters) in EMAIL_PASSWORD, not your regular password
# 4. This provides secure email sending without exposing your main password
